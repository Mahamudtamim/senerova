# ----- CREDENTIALS — NEVER COMMIT THESE --------------------
ADMIN_LOGIN.txt
ADMIN_LOGIN*
admin_login*
admin-login*
credentials.txt
credentials*
secrets.txt
secrets*
*.secret
*.credentials
.env
.env.*
.env.local
.env.development
.env.production
.env.*.local

# ----- macOS ------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
*.icloud

# ----- Windows ----------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# ----- Linux ------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ----- Editors & IDEs ---------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.iml
.project
.classpath
.settings/

# ----- Node.js (if you add a build step later) --------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm
.yarn/
.pnp.*

# ----- Build Output -----------------------------------------
dist/
build/
out/
.output/
.cache/
.parcel-cache/
.nuxt/
.next/
.svelte-kit/

# ----- Logs -------------------------------------------------
logs/
*.log
npm-debug.log*
lerna-debug.log*

# ----- Testing & Coverage -----------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
*.lcov

# ----- Temporary Files --------------------------------------
*.tmp
*.temp
*.bak
*.orig
.temp/
tmp/

# ----- Deployment -------------------------------------------
